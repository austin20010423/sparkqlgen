OPENAI_API_KEY=

# Groq API key for open-weight models (openai/gpt-oss-120b, ...). Optional.
GROQ_API_KEY=

# Default model on startup. Allowed: gpt-5.4, gpt-5.4-mini, gpt-4o-mini, openai/gpt-oss-120b
SPARQLGEN_DEFAULT_MODEL=gpt-5.4-mini

# Wikidata
WIKIDATA_USER_AGENT=sparqlgen/0.1 (chaoshiangchen@gmail.com)
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
