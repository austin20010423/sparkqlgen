OPENAI_API_KEY=

# Default model on startup. Allowed: gpt-5.4, gpt-4o, gpt-4o-mini, llama3.1:8b
SPARQLGEN_DEFAULT_MODEL=gpt-4o

# Local Llama via Ollama (OpenAI-compatible). Pull the model first:
#   ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Wikidata
WIKIDATA_USER_AGENT=sparqlgen/0.1 (chaoshiangchen@gmail.com)
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql
